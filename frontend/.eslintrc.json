{
  "extends": "next/core-web-vitals",
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "warn",
    "prefer-const": "error",
    "no-var": "error",
    "eqeqeq": ["error", "smart"],
    "curly": ["error", "multi-line"],
    "no-throw-literal": "error",
    "prefer-template": "warn",
    "object-shorthand": "warn",
    "dot-notation": "warn"
  }
}
